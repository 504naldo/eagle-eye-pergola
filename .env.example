# Copy this file to .env and fill in every value before running docker compose up.

# ── App ────────────────────────────────────────────────────────────────────────
# Host port the app listens on (default 3000)
PORT=3000

# Internal app identifier (used by the Manus runtime plugin)
VITE_APP_ID=eagle-eye-pergola

# ── Security ──────────────────────────────────────────────────────────────────
# Long random string used to sign session cookies — minimum 32 characters.
# Generate one with:  openssl rand -hex 32
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# ── Authentication (OAuth) ────────────────────────────────────────────────────
# Base URL of the OAuth / identity provider used for login
OAUTH_SERVER_URL=https://your-oauth-provider.example.com

# OpenID subject of the admin account (gets the "admin" role on first sign-in)
OWNER_OPEN_ID=your-openid-here

# ── Database ──────────────────────────────────────────────────────────────────
# Passwords for the MySQL container.  DATABASE_URL is assembled automatically
# in docker-compose.yml — do not set DATABASE_URL here.
DB_PASSWORD=change_this_strong_password
DB_ROOT_PASSWORD=change_this_root_password

# ── AI + File Storage (Manus Forge) ──────────────────────────────────────────
# Required for AI renderings, LLM project summaries, and file storage.
BUILT_IN_FORGE_API_URL=https://forge.manus.im
BUILT_IN_FORGE_API_KEY=your-forge-api-key-here
