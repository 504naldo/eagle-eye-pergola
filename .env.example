# Copy this file to .env and fill in every value before running docker compose up.

# ── App ────────────────────────────────────────────────────────────────────────
# Host port the app listens on (default 3000)
PORT=3000

# Internal app identifier
VITE_APP_ID=eagle-eye-pergola

# ── Security ──────────────────────────────────────────────────────────────────
# Long random string used to sign session cookies — minimum 32 characters.
# Generate one with:  openssl rand -hex 32
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# ── Database ──────────────────────────────────────────────────────────────────
# Passwords for the MySQL container.  DATABASE_URL is assembled automatically
# in docker-compose.yml — do not set DATABASE_URL here.
DB_PASSWORD=change_this_strong_password
DB_ROOT_PASSWORD=change_this_root_password

# ── AI: Anthropic (Claude) ────────────────────────────────────────────────────
# Used for AI project summaries.
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── AI: Stability AI (image generation) ──────────────────────────────────────
# Used for photorealistic pergola renderings.
# Get your key at: https://platform.stability.ai/
STABILITY_API_KEY=sk-your-stability-key-here

# ── File Storage: AWS S3 ──────────────────────────────────────────────────────
# Used for storing uploaded files and AI-generated images.
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
S3_BUCKET=your-s3-bucket-name
S3_REGION=us-east-1
